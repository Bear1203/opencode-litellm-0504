# opencode-litellm 設定檔
#
# 安裝程式會自動把這個檔案複製到 ~/.config/opencode/litellm.env,
# 之後可以用 `opencode-litellm config` 互動式修改,或直接編輯本檔。
#
# 注意: 本檔會被自動 source,只能用 KEY=VALUE 格式,不要寫 shell 語法。
#
# === 安全性說明 ===
# 為了避免 token 同時存在多個檔案,本檔「不存放 LITELLM_API_KEY」。
# 你的 API key 只會存在 ~/.config/opencode/litellm-key (mode 600),
# opencode.json 透過 {file:...} 引用該檔。
# 改 key 請執行: opencode-litellm config

# === 必填 ===
LITELLM_BASE_URL=https://litellm.example.com

# === 可選 ===
# 在 opencode 選單顯示的 provider 名稱 (可用 `opencode-litellm config` 互動修改)
LITELLM_PROVIDER_NAME=LiteLLM

# 取消註解才會覆寫預設
# LITELLM_PROVIDER_ID=litellm           # opencode provider id
# LITELLM_TIMEOUT=10                    # /v1/models 請求的 timeout 秒數
