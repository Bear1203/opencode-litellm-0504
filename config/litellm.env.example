# opencode-litellm 設定檔
# 複製成 ~/.config/opencode/litellm.env 後填入你的 API key
#
# 注意: 這個檔案會被 opencode-litellm 自動 source,不要寫入 shell 語法
#       (只能 KEY=VALUE 格式)

# === 必填 ===
LITELLM_API_KEY=sk-please-replace-me
LITELLM_BASE_URL=https://litellm.example.com

# === 可選 (取消註解才會覆寫預設) ===
# LITELLM_PROVIDER_ID=litellm
# LITELLM_PROVIDER_NAME=LiteLLM
# LITELLM_TIMEOUT=5
# LITELLM_CACHE_FILE=$HOME/.cache/opencode/litellm-models.json
# LITELLM_LOG_FILE=$HOME/.cache/opencode/litellm-sync.log
