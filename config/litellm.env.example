# opencode-litellm 設定檔 (Windows)
#
# 安裝程式會把這個檔案複製到 %USERPROFILE%\.config\opencode\litellm.env。
# 之後可以用 `opencode-litellm config` 互動式修改,或直接編輯本檔。
#
# 本檔以 KEY=VALUE 一行一筆解析,不支援 shell 語法。
# API key 不存在這裡,只存在 %USERPROFILE%\.config\opencode\litellm-key (僅本人可讀)。

# === 必填 (首次啟動時可按 Enter 套用此預設值) ===
LITELLM_BASE_URL=https://litellm-server.pic-ai.work

# === 可選 ===
# 在 opencode 選單顯示的 provider 名稱
LITELLM_PROVIDER_NAME=PIC-Litellm

# 取消註解才會覆寫預設
# LITELLM_PROVIDER_ID=litellm           # opencode provider id
# LITELLM_TIMEOUT=10                    # /v1/models 請求 timeout 秒數
