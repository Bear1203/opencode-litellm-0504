#!/usr/bin/env bash
# opencode-litellm — 把 LiteLLM 模型清單整合進 opencode
#
# 用法 (詳見 --help):
#   opencode-litellm                啟動 opencode (首次會引導設定 + 同步模型)
#   opencode-litellm sync           重新同步模型清單到 opencode.json
#   opencode-litellm config         互動式修改 API key / URL
#   opencode-litellm doctor         檢查環境設定狀態
#   opencode-litellm --version      顯示版本
#   opencode-litellm --help         顯示說明

set -euo pipefail

# ============================================================================
# 常數 & 路徑
# ============================================================================
readonly VERSION="0.1.0"
readonly PLACEHOLDER_KEY="sk-please-replace-me"
readonly PLACEHOLDER_URL="https://litellm.example.com"
readonly DEFAULT_PROVIDER_NAME="LiteLLM"

ENV_FILE="${LITELLM_ENV_FILE:-$HOME/.config/opencode/litellm.env}"
SYNC_SCRIPT="${LITELLM_SYNC_SCRIPT:-$HOME/.config/opencode/litellm-sync.sh}"
CONFIG_FILE="${OPENCODE_CONFIG_FILE:-$HOME/.config/opencode/opencode.json}"
KEY_FILE="${LITELLM_KEY_FILE:-$HOME/.config/opencode/litellm-key}"

# 載入 .env (current shell 的 export 優先,.env 用作 fallback)
# 注意: 本工具新版設計把 LITELLM_API_KEY 從 env 拿掉,只存 KEY_FILE。
# 但仍兼容舊版 env 內含 LITELLM_API_KEY 的情況 (見 migrate_env_key_to_file)。
if [[ -f "$ENV_FILE" ]]; then
  # shellcheck disable=SC1090
  set -a; source "$ENV_FILE"; set +a
fi

PROVIDER_ID="${LITELLM_PROVIDER_ID:-litellm}"
PROVIDER_NAME="${LITELLM_PROVIDER_NAME:-$DEFAULT_PROVIDER_NAME}"

# 若 env 沒給 KEY (新版設計),從 KEY_FILE 載入到記憶體變數
# 這個變數只存活在當前 process 中,不會被寫回任何檔
if [[ -z "${LITELLM_API_KEY:-}" && -f "$KEY_FILE" ]]; then
  LITELLM_API_KEY="$(cat "$KEY_FILE" 2>/dev/null || true)"
  export LITELLM_API_KEY
fi

# ============================================================================
# 輸出工具 (統一訊息風格)
# ============================================================================
info() { printf '[opencode-litellm] %s\n' "$*"; }
warn() { printf '[opencode-litellm] WARN: %s\n' "$*" >&2; }
err()  { printf '[opencode-litellm] ERROR: %s\n' "$*" >&2; }
ok()   { printf '[opencode-litellm] ✓ %s\n' "$*"; }

# ============================================================================
# .env 檔案維護
# ============================================================================
ensure_env_file() {
  [[ -f "$ENV_FILE" ]] && return 0
  mkdir -p "$(dirname "$ENV_FILE")"
  cat > "$ENV_FILE" <<'TEMPLATE'
# opencode-litellm 設定檔 (KEY=VALUE,不要寫 shell 語法)
#
# API key 不存在這裡,只存在 ~/.config/opencode/litellm-key (mode 600)。
# 改 key 請執行: opencode-litellm config

LITELLM_BASE_URL=https://litellm.example.com

# === 可選 ===
# LITELLM_PROVIDER_ID=litellm
LITELLM_PROVIDER_NAME=LiteLLM
# LITELLM_TIMEOUT=10
TEMPLATE
  chmod 600 "$ENV_FILE"
}

# 把 token 寫進 KEY_FILE (mode 600,原子寫入)
write_key_file() {
  local value="$1" tmp
  mkdir -p "$(dirname "$KEY_FILE")"
  tmp="$(mktemp "${KEY_FILE}.XXXXXX")"
  (umask 077; printf '%s' "$value" > "$tmp")
  chmod 600 "$tmp"
  mv -f "$tmp" "$KEY_FILE"
}

# 從舊版 env 把 LITELLM_API_KEY 搬到 KEY_FILE 並從 env 移除
# 條件: env 裡有非 placeholder 的 KEY,而且 KEY_FILE 不存在或為空
migrate_env_key_to_file() {
  [[ -f "$ENV_FILE" ]] || return 0
  # env 必須真的有 LITELLM_API_KEY= 這行 (避免只是當前 shell 有 export)
  grep -q '^LITELLM_API_KEY=' "$ENV_FILE" 2>/dev/null || return 0
  local env_key
  env_key="$(grep -E '^LITELLM_API_KEY=' "$ENV_FILE" | head -n1 | sed 's/^LITELLM_API_KEY=//')"
  [[ -z "$env_key" || "$env_key" == "$PLACEHOLDER_KEY" ]] && return 0

  # 若 KEY_FILE 已有內容就尊重它,不用 env 蓋過去 (但仍要清掉 env 的 KEY 行)
  if [[ ! -s "$KEY_FILE" ]]; then
    info "偵測到舊版設定: 將 API key 從 $ENV_FILE 搬到 $KEY_FILE (更安全)"
    write_key_file "$env_key"
  else
    info "偵測到舊版設定: $ENV_FILE 含 LITELLM_API_KEY,將其移除 (KEY_FILE 已有 token)"
  fi
  # 把 env 內的 LITELLM_API_KEY=... 行刪掉
  sed -i '/^LITELLM_API_KEY=/d' "$ENV_FILE"
  ok "遷移完成,API key 現在只存在 $KEY_FILE"
}

# 寫入或更新 .env 中的 KEY=VALUE (支援取消註解)
update_env_key() {
  local key="$1" value="$2"
  ensure_env_file
  if grep -q "^${key}=" "$ENV_FILE" 2>/dev/null; then
    sed -i "s|^${key}=.*|${key}=${value}|" "$ENV_FILE"
  elif grep -q "^# *${key}=" "$ENV_FILE" 2>/dev/null; then
    sed -i "s|^# *\(${key}=\).*|\1${value}|" "$ENV_FILE"
  else
    printf '%s=%s\n' "$key" "$value" >> "$ENV_FILE"
  fi
}

# ============================================================================
# 設定狀態檢查
# ============================================================================
api_key_is_set()  { [[ -n "${LITELLM_API_KEY:-}"  && "$LITELLM_API_KEY"  != "$PLACEHOLDER_KEY" ]]; }
base_url_is_set() { [[ -n "${LITELLM_BASE_URL:-}" && "$LITELLM_BASE_URL" != "$PLACEHOLDER_URL" ]]; }
provider_name_is_set() { [[ -n "${LITELLM_PROVIDER_NAME:-}" ]]; }

# 簡易 URL 格式驗證
url_is_valid() {
  [[ "$1" =~ ^https?://[^[:space:]]+$ ]]
}

# 檢查 opencode.json 是否已含 provider.<id> 且 models 非空
config_has_provider() {
  [[ -f "$CONFIG_FILE" ]] || return 1
  PROVIDER_ID="$PROVIDER_ID" CONFIG_FILE="$CONFIG_FILE" python3 - <<'PY' 2>/dev/null
import json, os, sys
try:
    with open(os.environ["CONFIG_FILE"], encoding="utf-8") as f:
        cfg = json.load(f)
    models = cfg.get("provider", {}).get(os.environ["PROVIDER_ID"], {}).get("models", {})
    sys.exit(0 if isinstance(models, dict) and models else 1)
except Exception:
    sys.exit(1)
PY
}

# 啟動 / sync 前的必要條件檢查
require_credentials() {
  if [[ ! -x "$SYNC_SCRIPT" ]]; then
    err "找不到 sync 腳本: $SYNC_SCRIPT"
    err "請重新執行安裝: curl -fsSL https://raw.githubusercontent.com/Bear1203/opencode-litellm-0504/main/install.sh | bash"
    return 1
  fi
  if ! api_key_is_set || ! base_url_is_set; then
    err "LITELLM_API_KEY 或 LITELLM_BASE_URL 尚未設定。"
    info "執行 'opencode-litellm config' 以互動式設定 (推薦)。"
    return 1
  fi
}

# ============================================================================
# 互動式輸入工具
# ============================================================================
# 把 key 顯示成 sk-abc...xy 形式以避免完全外露
mask_key() {
  local k="$1"
  if (( ${#k} > 10 )); then
    printf '%s...%s' "${k:0:6}" "${k: -2}"
  else
    printf '******'
  fi
}

# 提示輸入 LITELLM_API_KEY (空值會 retry,可選 allow_keep)
prompt_api_key() {
  local allow_keep="${1:-no}" input
  while true; do
    if [[ "$allow_keep" == "yes" ]] && api_key_is_set; then
      printf '新的 LITELLM_API_KEY (Enter 保留 %s): ' "$(mask_key "$LITELLM_API_KEY")"
    else
      printf 'LITELLM_API_KEY (你的 LiteLLM API key): '
    fi
    read -r input
    if [[ -z "$input" ]]; then
      [[ "$allow_keep" == "yes" ]] && return 0
      warn "不能為空,請重新輸入 (或 Ctrl+C 中止)"
      continue
    fi
    write_key_file "$input"
    LITELLM_API_KEY="$input"
    export LITELLM_API_KEY
    ok "已儲存 LITELLM_API_KEY → $KEY_FILE (mode 600)"
    return 0
  done
}

# 提示輸入 LITELLM_BASE_URL (空值會 retry,可選 allow_keep)
prompt_base_url() {
  local allow_keep="${1:-no}" input
  while true; do
    if [[ "$allow_keep" == "yes" ]] && base_url_is_set; then
      printf '新的 LITELLM_BASE_URL (Enter 保留 %s): ' "$LITELLM_BASE_URL"
    else
      printf 'LITELLM_BASE_URL (例如 https://litellm.example.com): '
    fi
    read -r input
    if [[ -z "$input" ]]; then
      [[ "$allow_keep" == "yes" ]] && return 0
      warn "不能為空,請重新輸入 (或 Ctrl+C 中止)"
      continue
    fi
    input="${input%/}"  # 去尾巴 /
    if ! url_is_valid "$input"; then
      warn "URL 必須以 http:// 或 https:// 開頭,請重新輸入"
      continue
    fi
    update_env_key "LITELLM_BASE_URL" "$input"
    LITELLM_BASE_URL="$input"
    ok "已儲存 LITELLM_BASE_URL"
    return 0
  done
}

# 提示輸入 LITELLM_PROVIDER_NAME (空字串會套用預設 LiteLLM,可選 allow_keep)
prompt_provider_name() {
  local allow_keep="${1:-no}" input current="${LITELLM_PROVIDER_NAME:-$DEFAULT_PROVIDER_NAME}"
  if [[ "$allow_keep" == "yes" ]]; then
    printf '新的 LITELLM_PROVIDER_NAME (opencode 選單顯示名稱,Enter 保留 %s): ' "$current"
  else
    printf 'LITELLM_PROVIDER_NAME (opencode 選單顯示名稱,Enter 套用預設 %s): ' "$DEFAULT_PROVIDER_NAME"
  fi
  read -r input
  if [[ -z "$input" ]]; then
    [[ "$allow_keep" == "yes" ]] && return 0
    input="$DEFAULT_PROVIDER_NAME"
  fi
  update_env_key "LITELLM_PROVIDER_NAME" "$input"
  LITELLM_PROVIDER_NAME="$input"
  PROVIDER_NAME="$input"
  ok "已儲存 LITELLM_PROVIDER_NAME ($input)"
  return 0
}

# ============================================================================
# 子指令實作
# ============================================================================

# sync — 重新拉取模型清單寫入 opencode.json
run_sync() {
  require_credentials || return 1
  info "同步 LiteLLM 模型清單 → $CONFIG_FILE"
  if "$SYNC_SCRIPT"; then
    ok "同步完成"
    return 0
  else
    err "同步失敗,詳情請見 ~/.cache/opencode/litellm-sync.log"
    info "若 URL 或 token 錯誤,執行 'opencode-litellm config' 修正後重試"
    return 1
  fi
}

# config — 重新跑互動設定 + 同步一次
run_config() {
  info "重新設定 LiteLLM 連線資訊"
  echo
  ensure_env_file
  prompt_api_key  yes
  echo
  prompt_base_url yes
  echo
  prompt_provider_name yes
  echo
  info "套用新設定並同步模型..."
  echo
  run_sync
}

# doctor — 環境健康檢查
run_doctor() {
  local issues=0
  echo "[opencode-litellm] 環境檢查"
  echo

  # 注意: 用 issues=$((issues+1)) 而非 ((issues++)),後者第一次回傳 0 會觸發 set -e
  printf '  opencode 指令       : '
  if command -v opencode >/dev/null 2>&1; then
    echo "✓ $(command -v opencode)"
  else
    echo "✗ 找不到 (curl -fsSL https://opencode.ai/install | bash)"
    issues=$((issues+1))
  fi

  printf '  litellm-sync.sh     : '
  if [[ -x "$SYNC_SCRIPT" ]]; then
    echo "✓ $SYNC_SCRIPT"
  else
    echo "✗ 不存在或無執行權限: $SYNC_SCRIPT"
    issues=$((issues+1))
  fi

  printf '  litellm.env         : '
  if [[ -f "$ENV_FILE" ]]; then
    local env_mode
    env_mode="$(stat -c '%a' "$ENV_FILE" 2>/dev/null || echo '?')"
    if [[ "$env_mode" == "600" ]]; then
      echo "✓ $ENV_FILE (mode 600)"
    else
      echo "⚠ $ENV_FILE (mode $env_mode,建議 chmod 600)"
    fi
    # 額外檢查: 新版設計 env 不該含 LITELLM_API_KEY
    if grep -q '^LITELLM_API_KEY=' "$ENV_FILE" 2>/dev/null; then
      printf '%-22s    ' '  └─'
      echo "⚠ 偵測到 LITELLM_API_KEY 寫在 env 裡 (跑 'opencode-litellm config' 會自動搬到 $KEY_FILE)"
    fi
  elif api_key_is_set && base_url_is_set; then
    echo "ℹ 不存在 (但 shell 中已 export 變數,可運作)"
  else
    echo "✗ 不存在 (跑 'opencode-litellm config' 即可建立)"
    issues=$((issues+1))
  fi

  printf '  LITELLM_API_KEY     : '
  if api_key_is_set; then
    echo "✓ 已設定 ($(mask_key "$LITELLM_API_KEY"))"
  else
    echo "✗ 未設定 (跑 'opencode-litellm config')"
    issues=$((issues+1))
  fi

  printf '  LITELLM_BASE_URL    : '
  if base_url_is_set; then
    echo "✓ ${LITELLM_BASE_URL}"
  else
    echo "✗ 未設定 (跑 'opencode-litellm config')"
    issues=$((issues+1))
  fi

  printf '  LITELLM_PROVIDER_NAME : '
  echo "✓ ${PROVIDER_NAME} (opencode 選單顯示名稱)"

  printf '  opencode.json       : '
  if config_has_provider; then
    echo "✓ $CONFIG_FILE (含 provider.$PROVIDER_ID)"
  else
    echo "✗ 缺 provider.$PROVIDER_ID (跑 'opencode-litellm sync')"
    issues=$((issues+1))
  fi

  printf '  litellm-key (token) : '
  if [[ -f "$KEY_FILE" ]]; then
    local mode
    mode="$(stat -c '%a' "$KEY_FILE" 2>/dev/null || echo '?')"
    if [[ "$mode" == "600" ]]; then
      echo "✓ $KEY_FILE (mode 600)"
    else
      echo "⚠ $KEY_FILE (mode $mode,建議 chmod 600)"
    fi
  else
    echo "✗ 不存在 (跑 'opencode-litellm sync' 即可建立)"
    issues=$((issues+1))
  fi

  echo
  if (( issues == 0 )); then
    ok "一切正常,可以直接打 'opencode' 或 'opencode-litellm' 啟動。"
    return 0
  else
    err "發現 $issues 個問題,請依上面提示修正。"
    return 1
  fi
}

# 首次設定 (僅給「正常啟動」路徑用)
run_first_time_setup_if_needed() {
  api_key_is_set && base_url_is_set && return 0

  info "尚未完成設定,請依序輸入:"
  echo
  api_key_is_set  || prompt_api_key
  echo
  base_url_is_set || prompt_base_url
  echo
  prompt_provider_name
  echo
  info "設定完成,繼續啟動..."
  echo
}

# --help / --version
show_help() {
  cat <<EOF
opencode-litellm v$VERSION

用法:
  opencode-litellm                啟動 opencode (首次會引導設定 + 同步模型)
  opencode-litellm <opencode args>   參數會原樣傳給 opencode (如 'run "hello"')

子指令:
  sync          重新同步 LiteLLM 模型清單到 opencode.json
  config        互動式修改 LITELLM_API_KEY / LITELLM_BASE_URL / LITELLM_PROVIDER_NAME 後重新同步
  doctor        檢查環境與設定狀態
  --help, -h    顯示本說明
  --version     顯示版本

設定檔:
  $ENV_FILE       (LITELLM_BASE_URL / LITELLM_PROVIDER_NAME 等非機密設定)
  $KEY_FILE       (純 API token,opencode.json 用 {file:...} 引用,mode 600)
  $CONFIG_FILE    (opencode 主設定,含 provider.$PROVIDER_ID)

詳細文件: https://github.com/Bear1203/opencode-litellm-0504
EOF
}

# ============================================================================
# 主流程
# ============================================================================

# 舊版 → 新版資料遷移 (env 內含 LITELLM_API_KEY 時搬到 KEY_FILE)
# help / version 不需要動到設定,可略過
case "${1:-}" in
  -h|--help|help|--version|version) ;;
  *) migrate_env_key_to_file ;;
esac

case "${1:-}" in
  sync)                shift; run_sync;   exit $? ;;
  config|configure)    shift; run_config; exit $? ;;
  doctor|check|status) shift; run_doctor; exit $? ;;
  -h|--help|help)      show_help;         exit 0  ;;
  --version|version)   echo "opencode-litellm v$VERSION"; exit 0 ;;
esac

# 正常啟動路徑
run_first_time_setup_if_needed

if ! config_has_provider; then
  info "首次啟動,先取得模型清單..."
  if ! run_sync; then
    err "無法取得模型清單,中止啟動。"
    info "修正設定後請執行: opencode-litellm config"
    exit 1
  fi
fi

if ! command -v opencode >/dev/null 2>&1; then
  cat >&2 <<EOF
[opencode-litellm] ERROR: 找不到 opencode 指令。

可能原因 / 解法:
  1. 還沒安裝 opencode
       curl -fsSL https://opencode.ai/install | bash
  2. 已安裝但不在 PATH (預設裝到 ~/.opencode/bin)
       echo 'export PATH="\$HOME/.opencode/bin:\$PATH"' >> ~/.bashrc
       source ~/.bashrc

模型清單與 token 已寫入,opencode 上線後即可直接使用,不必再跑此 wrapper。
EOF
  exit 127
fi

exec opencode "$@"
