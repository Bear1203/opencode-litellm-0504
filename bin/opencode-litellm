#!/usr/bin/env bash
# opencode-litellm
# 啟動 opencode,啟動前動態同步 LiteLLM 的可用模型清單。
#
# 用法:
#   opencode-litellm                      # = opencode
#   opencode-litellm run "hello"          # = opencode run "hello"
#
# 環境變數 (依優先序):
#   1. 當前 shell export 的變數
#   2. ~/.config/opencode/litellm.env    (key=value 格式, 自動載入)
#   3. 腳本內預設值
#
# 必要:
#   LITELLM_API_KEY        你的 LiteLLM API key
#   LITELLM_BASE_URL       LiteLLM server URL (例如 https://litellm.example.com)
#
# 可選:
#   LITELLM_PROVIDER_ID    (default litellm)
#   LITELLM_PROVIDER_NAME  (default "LiteLLM")
#   LITELLM_SYNC_SCRIPT    (default ~/.config/opencode/litellm-sync.sh)
#   LITELLM_ENV_FILE       (default ~/.config/opencode/litellm.env)

set -euo pipefail

ENV_FILE="${LITELLM_ENV_FILE:-$HOME/.config/opencode/litellm.env}"
SYNC_SCRIPT="${LITELLM_SYNC_SCRIPT:-$HOME/.config/opencode/litellm-sync.sh}"

# --- 載入 .env ---------------------------------------------------------------
# 只在使用者尚未自己 export 時才用 .env 的值 (current shell 優先)
if [[ -f "$ENV_FILE" ]]; then
  # shellcheck disable=SC1090
  set -a
  source "$ENV_FILE"
  set +a
fi

# --- 檢查必要條件 ------------------------------------------------------------
# 範本預設值,使用者忘了改也要擋下來
PLACEHOLDER_KEY="sk-please-replace-me"
PLACEHOLDER_URL="https://litellm.example.com"

# 檢查是否需要互動式設定
needs_interactive_setup=false

if [[ -z "${LITELLM_API_KEY:-}" || "${LITELLM_API_KEY}" == "$PLACEHOLDER_KEY" ]]; then
  needs_interactive_setup=true
fi

if [[ -z "${LITELLM_BASE_URL:-}" || "${LITELLM_BASE_URL}" == "$PLACEHOLDER_URL" ]]; then
  needs_interactive_setup=true
fi

# 互動式設定:偵測到 placeholder 或空值時,引導使用者輸入並自動寫入 .env
if $needs_interactive_setup; then
  echo "[opencode-litellm] 尚未完成設定,請回答以下問題:"
  echo ""

  # 讀取 .env 中既有行號,用於原地替換
  ensure_env_file() {
    if [[ ! -f "$ENV_FILE" ]]; then
      mkdir -p "$(dirname "$ENV_FILE")"
      cat > "$ENV_FILE" <<'TEMPLATE'
# opencode-litellm 設定檔
LITELLM_API_KEY=sk-please-replace-me
LITELLM_BASE_URL=https://litellm.example.com

# === 可選 (取消註解才會覆寫預設) ===
# LITELLM_PROVIDER_ID=litellm
# LITELLM_PROVIDER_NAME=LiteLLM
TEMPLATE
      chmod 600 "$ENV_FILE"
    fi
  }

  # 更新 .env 中的 KEY=VALUE 行 (支援已註解的列)
  update_env_key() {
    local key="$1" value="$2"
    ensure_env_file
    # 先嘗試替換未註解的行
    if grep -q "^${key}=" "$ENV_FILE" 2>/dev/null; then
      sed -i "s|^${key}=.*|${key}=${value}|" "$ENV_FILE"
    elif grep -q "^# *${key}=" "$ENV_FILE" 2>/dev/null; then
      # 替換已註解的行 → 取消註解並寫入新值
      sed -i "s|^# *\(${key}=\).*|\1${value}|" "$ENV_FILE"
    else
      # 追加到檔案末尾
      echo "${key}=${value}" >> "$ENV_FILE"
    fi
  }

  if [[ -z "${LITELLM_API_KEY:-}" || "${LITELLM_API_KEY}" == "$PLACEHOLDER_KEY" ]]; then
    echo -n "LITELLM_API_KEY (你的 LiteLLM API key): "
    read -r input_key
    if [[ -n "$input_key" ]]; then
      update_env_key "LITELLM_API_KEY" "$input_key"
      LITELLM_API_KEY="$input_key"
      echo "  → 已儲存"
    else
      echo "[opencode-litellm] ERROR: LITELLM_API_KEY 不能為空"
      exit 1
    fi
    echo ""
  fi

  if [[ -z "${LITELLM_BASE_URL:-}" || "${LITELLM_BASE_URL}" == "$PLACEHOLDER_URL" ]]; then
    echo -n "LITELLM_BASE_URL (例如 https://litellm.your-company.internal): "
    read -r input_url
    if [[ -n "$input_url" ]]; then
      # 移除結尾斜線 (避免 double-slash)
      input_url="${input_url%/}"
      update_env_key "LITELLM_BASE_URL" "$input_url"
      LITELLM_BASE_URL="$input_url"
      echo "  → 已儲存"
    else
      echo "[opencode-litellm] ERROR: LITELLM_BASE_URL 不能為空"
      exit 1
    fi
    echo ""
  fi

  echo "[opencode-litellm] 設定已完成，繼續啟動..."
  echo ""
fi

if [[ -z "${LITELLM_API_KEY:-}" || "${LITELLM_API_KEY}" == "$PLACEHOLDER_KEY" ]]; then
  cat >&2 <<EOF
[opencode-litellm] ERROR: LITELLM_API_KEY is not set or still the placeholder value.

請選一種方式設定:
  1. 編輯 $ENV_FILE 並填入 LITELLM_API_KEY=sk-...
  2. 或在當前 shell 執行 export LITELLM_API_KEY=sk-...
EOF
  exit 1
fi

if [[ -z "${LITELLM_BASE_URL:-}" || "${LITELLM_BASE_URL}" == "$PLACEHOLDER_URL" ]]; then
  cat >&2 <<EOF
[opencode-litellm] ERROR: LITELLM_BASE_URL is not set or still the placeholder value.

請選一種方式設定:
  1. 編輯 $ENV_FILE 並填入 LITELLM_BASE_URL=https://your-litellm-host
  2. 或在當前 shell 執行 export LITELLM_BASE_URL=https://your-litellm-host
EOF
  exit 1
fi

if [[ ! -x "$SYNC_SCRIPT" ]]; then
  echo "[opencode-litellm] ERROR: sync script not found or not executable: $SYNC_SCRIPT" >&2
  exit 1
fi

# --- 動態產生 inline config -------------------------------------------------
# OPENCODE_CONFIG_CONTENT 會跟使用者 ~/.config/opencode/opencode.json 合併
OPENCODE_CONFIG_CONTENT="$("$SYNC_SCRIPT")"
export OPENCODE_CONFIG_CONTENT
export LITELLM_API_KEY

exec opencode "$@"
